# syntax=docker/dockerfile:1.7
FROM node:20-alpine AS builder

ENV PNPM_HOME=/pnpm
ENV PATH=$PNPM_HOME:$PATH
RUN corepack enable && corepack prepare pnpm@10.32.1 --activate
WORKDIR /app

COPY package.json pnpm-lock.yaml pnpm-workspace.yaml .npmrc ./
COPY apps/web/package.json apps/web/package.json
COPY apps/api/package.json apps/api/package.json
COPY packages/shared-types/package.json packages/shared-types/package.json
RUN --mount=type=cache,id=pnpm,target=/pnpm/store pnpm install --frozen-lockfile --filter "web..."

COPY tsconfig.base.json turbo.json ./
COPY apps/web apps/web
COPY packages/shared-types packages/shared-types
RUN pnpm --filter web build

FROM nginx:1.31-alpine AS runtime
COPY docker/nginx.conf /etc/nginx/nginx.http.conf
COPY docker/nginx.tls.conf /etc/nginx/nginx.tls.conf
COPY --chmod=755 docker/20-enable-tls.sh /docker-entrypoint.d/20-enable-tls.sh
COPY --from=builder /app/apps/web/out /usr/share/nginx/html
EXPOSE 80 443
HEALTHCHECK --interval=10s --timeout=3s --retries=5 CMD wget -qO- http://127.0.0.1/healthz || exit 1
