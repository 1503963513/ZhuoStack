{
  "name": "api",
  "version": "1.0.0",
  "private": true,
  "description": "NestJS API application",
  "scripts": {
    "build": "nest build",
    "dev": "nest start --watch",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "NODE_ENV=production node dist/src/main",
    "lint": "eslint \"{src,test}/**/*.ts\" --fix",
    "test": "NODE_OPTIONS=--experimental-vm-modules jest",
    "test:watch": "NODE_OPTIONS=--experimental-vm-modules jest --watch",
    "test:cov": "NODE_OPTIONS=--experimental-vm-modules jest --coverage",
    "test:e2e": "NODE_OPTIONS=--experimental-vm-modules jest --config ./test/jest-e2e.json",
    "db:use:pg": "rm -rf prisma/schema.active && cp -r prisma/postgres prisma/schema.active",
    "db:use:mysql": "rm -rf prisma/schema.active && cp -r prisma/mysql prisma/schema.active",
    "prisma:generate": "prisma generate --schema=prisma/schema.active",
    "prisma:migrate": "node --env-file-if-exists=.env.development ./node_modules/prisma/build/index.js migrate dev --schema=prisma/schema.active",
    "prisma:migrate:deploy": "node --env-file-if-exists=.env.production ./node_modules/prisma/build/index.js migrate deploy --schema=prisma/schema.active",
    "prisma:push": "node --env-file-if-exists=.env.development ./node_modules/prisma/build/index.js db push --schema=prisma/schema.active",
    "prisma:studio": "node --env-file-if-exists=.env.development ./node_modules/prisma/build/index.js studio --schema=prisma/schema.active",
    "prisma:seed": "node --env-file-if-exists=.env.development --import tsx prisma/seed.ts",
    "prisma:reset": "prisma migrate reset --schema=prisma/schema.active",
    "db:setup:pg": "pnpm db:use:pg && pnpm prisma:generate && pnpm prisma:migrate && pnpm prisma:seed",
    "db:setup:mysql": "pnpm db:use:mysql && pnpm prisma:generate && pnpm prisma:migrate && pnpm prisma:seed",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@fastify/helmet": "^13.1.0",
    "@fastify/multipart": "^10.1.0",
    "@fastify/static": "^9.3.0",
    "@nestjs/common": "^11.1.28",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.1.28",
    "@nestjs/event-emitter": "^3.1.0",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-fastify": "^11.1.28",
    "@nestjs/schedule": "^6.1.3",
    "@nestjs/swagger": "^11.4.6",
    "@nestjs/terminus": "^11.1.1",
    "@nestjs/throttler": "^6.5.0",
    "@prisma/client": "^5.8.0",
    "ali-oss": "^6.23.0",
    "bcryptjs": "^2.4.3",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "cos-nodejs-sdk-v5": "^3.0.0",
    "fastify": "^5.10.0",
    "file-type": "21.3.2",
    "ioredis": "^5.11.0",
    "openai": "^6.48.0",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "passport-local": "^1.0.0",
    "pm2": "^7.0.3",
    "prisma": "^5.8.0",
    "reflect-metadata": "^0.2.1",
    "rxjs": "^7.8.1",
    "svg-captcha": "^1.4.0",
    "tsx": "^4.7.0",
    "ua-parser-js": "^2.0.10"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.24",
    "@nestjs/schematics": "^11.1.0",
    "@nestjs/testing": "^11.1.28",
    "@types/ali-oss": "^6.23.3",
    "@types/bcryptjs": "^2.4.6",
    "@types/cron": "^2.4.3",
    "@types/ioredis": "^5.0.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^20.11.0",
    "@types/passport-jwt": "^4.0.0",
    "@types/passport-local": "^1.0.38",
    "@types/supertest": "^6.0.2",
    "@types/ua-parser-js": "^0.7.39",
    "jest": "^29.7.0",
    "supertest": "^6.3.3",
    "ts-jest": "^29.1.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.2.2"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node"
  }
}
