model User {
  id        String   @id @default(cuid())
  email     String   @unique(length: 50)
  name      String?  @db.VarChar(255)
  password  String
  role      Role     @default(USER)
  avatar    String?  @db.VarChar(500)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("users")
}
