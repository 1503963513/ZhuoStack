model SysDictData {
  id        String   @id @default(cuid())
  dictId    String
  label     String
  value     String
  sort      Int      @default(0)
  status    Status   @default(ACTIVE)
  remark    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  dict SysDict @relation(fields: [dictId], references: [id], onDelete: Cascade)

  @@index([dictId])
  @@index([status])
  @@map("sys_dict_data")
}
