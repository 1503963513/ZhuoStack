model SysRole {
  id        String   @id @default(cuid())
  name      String
  code      String   @unique
  sort      Int      @default(0)
  status    Status   @default(ACTIVE)
  remark    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users User[]
  menus SysMenu[]

  @@map("sys_role")
}
