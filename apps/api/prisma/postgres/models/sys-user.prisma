model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  password  String
  role      Role     @default(USER)
  avatar    String?
  deptId    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  dept  SysDept?  @relation(fields: [deptId], references: [id])
  roles SysRole[]
  posts SysPost[]

  @@index([deptId])
  @@index([role])
  @@index([createdAt])
  @@map("sys_user")
}
