# =============================================================================
# API 环境变量模板
# 本地开发：复制为 .env.development
# 生产部署：复制为 .env.production，并替换所有 CHANGE_ME 和云服务密钥
# =============================================================================

# --- 应用 ---------------------------------------------------------------------
NODE_ENV=development
PORT=3100
CORS_ORIGIN=http://localhost:3000

# --- 数据库 -------------------------------------------------------------------
# mysql | postgres
# 默认使用 PostgreSQL
DB_TYPE=postgres
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/myapp

# 使用本地 docker-compose.dev.yml 的 MySQL 时改为：
# DB_TYPE=mysql
# DATABASE_URL=mysql://root:root@localhost:3307/myapp

# --- Redis --------------------------------------------------------------------
REDIS_URL=redis://localhost:6379

# --- 认证与安全 ----------------------------------------------------------------
# 至少 32 个字符；生产环境必须使用随机密钥
JWT_SECRET=CHANGE_ME_generate_at_least_32_characters
JWT_EXPIRES_IN=8h
JWT_ISSUER=myapp-api
JWT_AUDIENCE=myapp-web
THROTTLE_TTL=60
THROTTLE_LIMIT=100

# 仅生产环境直接由 API 提供 HTTPS 时填写；使用 Nginx 终止 TLS 时留空
SSL_CERT_PATH=
SSL_KEY_PATH=

# --- API 文档 ------------------------------------------------------------------
SWAGGER_ENABLED=true

# --- AI（OpenAI 兼容接口） -----------------------------------------------------
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o
OPENAI_MAX_TOKENS=4096

# --- 文件上传：公共配置 -------------------------------------------------------
# local | aliyun | tencent；只决定新文件的存储位置
FILE_STORAGE_TYPE=local
FILE_MAX_SIZE_MB=50

# 可选：对象键前缀，例如 myapp/uploads；留空则使用 yyyy/mm/dd 目录
FILE_OBJECT_PREFIX=

# 高级配置：允许的 MIME 类型，英文逗号分隔
# 仅可配置服务端支持魔数/UTF-8 校验的类型；SVG/HTML 等主动内容禁止上传
FILE_ALLOWED_MIME_TYPES=image/jpeg,image/png,image/gif,image/webp,application/pdf,application/vnd.openxmlformats-officedocument.wordprocessingml.document,application/vnd.openxmlformats-officedocument.spreadsheetml.sheet,text/plain,text/csv,application/zip,video/mp4,video/webm,audio/mpeg

# --- 本地存储（FILE_STORAGE_TYPE=local） ----------------------------------------
FILE_STORAGE_PATH=uploads
FILE_URL_PREFIX=/files

# --- 阿里云 OSS（FILE_STORAGE_TYPE=aliyun） ---------------------------------------
# REGION 示例：oss-cn-hangzhou
ALIYUN_OSS_REGION=
ALIYUN_OSS_BUCKET=
ALIYUN_OSS_ACCESS_KEY_ID=
ALIYUN_OSS_ACCESS_KEY_SECRET=

# 可选：Endpoint 优先于 REGION；PUBLIC_URL 用于 CDN 或浏览器可访问域名
ALIYUN_OSS_ENDPOINT=
ALIYUN_OSS_PUBLIC_URL=

# --- 腾讯云 COS（FILE_STORAGE_TYPE=tencent） -------------------------------------
# Bucket 必须包含 APPID，例如 myapp-1250000000；Region 示例：ap-guangzhou
TENCENT_COS_REGION=
TENCENT_COS_BUCKET=
TENCENT_COS_SECRET_ID=
TENCENT_COS_SECRET_KEY=

# 可选：CDN 或浏览器可访问的自定义域名
TENCENT_COS_PUBLIC_URL=
