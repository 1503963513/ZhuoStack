# Next.js 环境变量配置
#
# 文件优先级（高→低）：.env.local > .env.development/.env.production > .env
#
# .env.development  → pnpm dev 时自动读取（git 跟踪，团队共享）
# .env.production   → pnpm build 时自动读取（git 跟踪，生产配置）
# .env.local        → 个人覆盖，优先级最高（gitignore，不提交）
# .env.example      → 本文件，模板文档

# 后端 API 地址
# 开发环境：http://localhost:3100（直连后端）
# 生产环境：留空（Nginx 同域代理 /api/* 到后端）
NEXT_PUBLIC_API_URL=http://localhost:3100
