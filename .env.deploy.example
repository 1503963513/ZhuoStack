# 复制为 .env.deploy 后使用。执行 `pnpm ops docker up` 会自动复制并生成 JWT_SECRET。
COMPOSE_PROJECT_NAME=myapp
APP_IMAGE_PREFIX=myapp
APP_VERSION=latest
WEB_PORT=3000
API_PORT=3100
TZ=Asia/Shanghai

# postgres | mysql。切换后需同步修改 DATABASE_URL。
DB_TYPE=postgres
DATABASE_URL=postgresql://myapp:myapp123@db:5432/myapp
DB_AUTO_SYNC=true

POSTGRES_USER=myapp
POSTGRES_PASSWORD=myapp123
POSTGRES_DB=myapp

# DB_TYPE=mysql 时使用：
MYSQL_ROOT_PASSWORD=root123
MYSQL_DATABASE=myapp
MYSQL_USER=myapp
MYSQL_PASSWORD=myapp123
# DATABASE_URL=mysql://myapp:myapp123@db:3306/myapp

REDIS_URL=redis://redis:6379
JWT_SECRET=CHANGE_ME_THE_DEPLOY_SCRIPT_WILL_GENERATE_A_SECURE_SECRET
JWT_EXPIRES_IN=7d
NODE_ENV=production
PORT=3100
CORS_ORIGIN=http://localhost:3000
SWAGGER_ENABLED=false

THROTTLE_TTL=60
THROTTLE_LIMIT=100

OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o
OPENAI_MAX_TOKENS=4096

# local | aliyun | tencent
FILE_STORAGE_TYPE=local
FILE_OBJECT_PREFIX=
FILE_STORAGE_PATH=/app/apps/api/uploads
FILE_URL_PREFIX=/files
FILE_MAX_SIZE_MB=50

# FILE_STORAGE_TYPE=aliyun 时填写
ALIYUN_OSS_REGION=
ALIYUN_OSS_ENDPOINT=
ALIYUN_OSS_BUCKET=
ALIYUN_OSS_ACCESS_KEY_ID=
ALIYUN_OSS_ACCESS_KEY_SECRET=
ALIYUN_OSS_PUBLIC_URL=

# FILE_STORAGE_TYPE=tencent 时填写，Bucket 需包含 APPID
TENCENT_COS_REGION=
TENCENT_COS_BUCKET=
TENCENT_COS_SECRET_ID=
TENCENT_COS_SECRET_KEY=
TENCENT_COS_PUBLIC_URL=
