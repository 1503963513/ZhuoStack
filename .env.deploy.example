# 复制为 .env.deploy 后使用。执行 `pnpm ops docker up` 会自动复制并生成 JWT_SECRET。
COMPOSE_PROJECT_NAME=zhuostack
APP_IMAGE_PREFIX=zhuostack
APP_VERSION=latest
WEB_PORT=80
WEB_TLS_PORT=443
# 可选：目录内放置 tls.crt 与 tls.key；也可由外部负载均衡器终止 HTTPS。
TLS_CERT_DIR=./docker/certs
API_PORT=3100
TZ=Asia/Shanghai

# 容器资源与日志上限（按宿主机容量调整）
DB_MEMORY_LIMIT=1g
DB_CPU_LIMIT=1.0
REDIS_MEMORY_LIMIT=256m
REDIS_CPU_LIMIT=0.5
API_MEMORY_LIMIT=512m
API_CPU_LIMIT=1.0
WEB_MEMORY_LIMIT=256m
WEB_CPU_LIMIT=0.5
LOG_MAX_SIZE=10m
LOG_MAX_FILES=5

# postgres | mysql。切换后需同步修改 DATABASE_URL。
DB_TYPE=postgres
DATABASE_URL=postgresql://zhuostack:zhuostack123@db:5432/zhuostack
DB_MIGRATE_ON_START=true

POSTGRES_USER=zhuostack
POSTGRES_PASSWORD=zhuostack123
POSTGRES_DB=zhuostack

# DB_TYPE=mysql 时使用：
MYSQL_ROOT_PASSWORD=root123
MYSQL_DATABASE=zhuostack
MYSQL_USER=zhuostack
MYSQL_PASSWORD=zhuostack123
# DATABASE_URL=mysql://zhuostack:zhuostack123@db:3306/zhuostack

REDIS_PASSWORD=CHANGE_ME_THE_DEPLOY_SCRIPT_WILL_GENERATE_A_SECURE_SECRET
REDIS_REQUIRED=true
JWT_SECRET=CHANGE_ME_THE_DEPLOY_SCRIPT_WILL_GENERATE_A_SECURE_SECRET
JWT_EXPIRES_IN=8h
JWT_ISSUER=zhuostack-api
JWT_AUDIENCE=zhuostack-web
NODE_ENV=production
PORT=3100
CORS_ORIGIN=https://localhost
SWAGGER_ENABLED=false

THROTTLE_TTL=60
THROTTLE_LIMIT=100
# 仅信任反向代理所在网段；禁止在生产环境配置为 true/*/all
TRUST_PROXY=loopback,linklocal,uniquelocal

OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o
OPENAI_MAX_TOKENS=4096

# local | aliyun | tencent
FILE_STORAGE_TYPE=local
FILE_OBJECT_PREFIX=
FILE_STORAGE_PATH=/app/apps/api/uploads
FILE_URL_PREFIX=/files
FILE_MAX_SIZE_MB=50
FILE_ALLOWED_MIME_TYPES=image/jpeg,image/png,image/gif,image/webp,application/pdf,application/vnd.openxmlformats-officedocument.wordprocessingml.document,application/vnd.openxmlformats-officedocument.spreadsheetml.sheet,text/plain,text/csv,application/zip,video/mp4,video/webm,audio/mpeg

# FILE_STORAGE_TYPE=aliyun 时填写
ALIYUN_OSS_REGION=
ALIYUN_OSS_ENDPOINT=
ALIYUN_OSS_BUCKET=
ALIYUN_OSS_ACCESS_KEY_ID=
ALIYUN_OSS_ACCESS_KEY_SECRET=
ALIYUN_OSS_PUBLIC_URL=

# FILE_STORAGE_TYPE=tencent 时填写，Bucket 需包含 APPID
TENCENT_COS_REGION=
TENCENT_COS_BUCKET=
TENCENT_COS_SECRET_ID=
TENCENT_COS_SECRET_KEY=
TENCENT_COS_PUBLIC_URL=
