{
  "name": "zhuostack",
  "version": "1.0.0",
  "private": true,
  "packageManager": "pnpm@10.32.1",
  "engines": {
    "node": ">=24 <25",
    "pnpm": ">=10 <11"
  },
  "description": "Production-oriented NestJS + Next.js full-stack monorepo",
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "build:deploy": "pnpm --filter api build && pnpm --filter web build",
    "typecheck": "turbo run typecheck",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "test:e2e": "pnpm --filter api test:e2e",
    "test:ci": "pnpm typecheck && pnpm lint && pnpm test && pnpm test:e2e",
    "audit:prod": "pnpm audit --prod --audit-level high",
    "db:migrate:pg": "pnpm --filter api db:migrate:pg",
    "db:migrate:mysql": "pnpm --filter api db:migrate:mysql",
    "db:generate:pg": "pnpm --filter api db:use:pg && pnpm --filter api prisma:generate",
    "db:generate:mysql": "pnpm --filter api db:use:mysql && pnpm --filter api prisma:generate",
    "db:verify:pg": "pnpm --filter api db:verify:pg",
    "db:verify:mysql": "pnpm --filter api db:verify:mysql",
    "db:baseline:pg": "pnpm --filter api db:baseline:pg",
    "db:baseline:mysql": "pnpm --filter api db:baseline:mysql",
    "db:seed": "pnpm --filter api prisma:seed",
    "ops": "bash scripts/deploy.sh",
    "docker:up": "bash scripts/deploy.sh docker up",
    "docker:down": "bash scripts/deploy.sh docker down",
    "release": "bash scripts/deploy.sh pack interactive",
    "clean": "turbo run clean && rm -rf node_modules"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@typescript-eslint/eslint-plugin": "^8.65.0",
    "@typescript-eslint/parser": "^8.65.0",
    "eslint": "^10.7.0",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.9.6",
    "turbo": "^2.10.6",
    "typescript": "^7.0.2"
  },
  "pnpm": {
    "overrides": {
      "brace-expansion@1.1.15": "1.1.16",
      "brace-expansion@2.1.1": "2.1.2",
      "fast-uri@3.1.2": "3.1.4",
      "form-data@4.0.5": "4.0.6",
      "js-yaml@3.14.2": "3.15.0",
      "js-yaml@4.1.1": "4.3.0",
      "minimatch@9.0.3": "9.0.7",
      "next@16.2.11>postcss": "8.5.15",
      "next@16.2.11>sharp": "0.35.3",
      "tsx@4.22.4>esbuild": "0.28.1"
    },
    "onlyBuiltDependencies": [
      "@nestjs/core",
      "@prisma/client",
      "@prisma/engines",
      "argon2",
      "esbuild",
      "prisma",
      "unrs-resolver"
    ]
  }
}
