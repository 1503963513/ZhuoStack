{
  "name": "my-fullstack-app",
  "version": "1.0.0",
  "private": true,
  "packageManager": "pnpm@10.32.1",
  "description": "NestJS + Next.js fullstack monorepo",
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "build:deploy": "pnpm --filter api build && pnpm --filter web build",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "db:migrate": "pnpm --filter api db:migrate",
    "db:generate": "pnpm --filter api db:generate",
    "db:seed": "pnpm --filter api prisma:seed",
    "ops": "bash scripts/deploy.sh",
    "docker:up": "bash scripts/deploy.sh docker up",
    "docker:down": "bash scripts/deploy.sh docker down",
    "release": "bash scripts/deploy.sh pack interactive",
    "clean": "turbo run clean && rm -rf node_modules"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^6.21.0",
    "@typescript-eslint/parser": "^6.21.0",
    "eslint": "^8.50.0",
    "eslint-config-prettier": "^9.1.2",
    "prettier": "^3.0.3",
    "turbo": "^2.9.14",
    "typescript": "^5.2.2"
  },
  "pnpm": {
    "overrides": {
      "brace-expansion@1.1.15": "1.1.16",
      "brace-expansion@2.1.1": "2.1.2",
      "fast-uri@3.1.2": "3.1.4",
      "form-data@4.0.5": "4.0.6",
      "js-yaml@3.14.2": "3.15.0",
      "js-yaml@4.1.1": "4.3.0",
      "minimatch@9.0.3": "9.0.7",
      "next@16.2.11>postcss": "8.5.15",
      "next@16.2.11>sharp": "0.35.3",
      "tsx@4.22.4>esbuild": "0.28.1"
    },
    "onlyBuiltDependencies": [
      "@nestjs/core",
      "@prisma/client",
      "@prisma/engines",
      "argon2",
      "esbuild",
      "prisma",
      "unrs-resolver"
    ]
  }
}
