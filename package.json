{
  "name": "my-fullstack-app",
  "version": "1.0.0",
  "private": true,
  "packageManager": "pnpm@10.32.1",
  "description": "NestJS + Next.js fullstack monorepo",
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "build:deploy": "pnpm --filter api build && pnpm --filter web build",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "db:migrate": "pnpm --filter api db:migrate",
    "db:generate": "pnpm --filter api db:generate",
    "db:seed": "pnpm --filter api prisma:seed",
    "ops": "bash scripts/deploy.sh",
    "docker:up": "bash scripts/deploy.sh docker up",
    "docker:down": "bash scripts/deploy.sh docker down",
    "release": "bash scripts/deploy.sh pack interactive",
    "clean": "turbo run clean && rm -rf node_modules"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^6.21.0",
    "@typescript-eslint/parser": "^6.21.0",
    "eslint": "^8.50.0",
    "eslint-config-prettier": "^9.1.2",
    "prettier": "^3.0.3",
    "turbo": "^1.10.14",
    "typescript": "^5.2.2"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@nestjs/core",
      "@prisma/client",
      "@prisma/engines",
      "argon2",
      "esbuild",
      "prisma",
      "unrs-resolver"
    ]
  }
}
